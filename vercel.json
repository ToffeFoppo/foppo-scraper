{
  "version": 2,
  "builds": [
    {
      "src": "api/*.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    { "src": "/api/scrape",  "dest": "/api/scrape.py"  },
    { "src": "/api/approve", "dest": "/api/approve.py" }
  ],
  "crons": [
    {
      "path": "/api/scrape",
      "schedule": "0 7 * * *"
    }
  ]
}
